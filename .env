# Application Configuration
# Server address and port
APP_ADDR=:8080

# Database configuration
# Supported drivers: mysql, sqlite
DB_DRIVER=sqlite

# SQLite database path (used when DB_DRIVER=sqlite)
SQLITE_PATH=data/demo.db

# MySQL DSN (used when DB_DRIVER=mysql)
# Format: user:password@tcp(host:port)/database?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_DSN=user:password@tcp(localhost:3306)/demo_db?charset=utf8mb4&parseTime=True&loc=Local