{
  "environment": "production",
  "server": {
    "addr": ":8081",
    "read_header_timeout_sec": 5,
    "read_timeout_sec": 120,
    "write_timeout_sec": 120,
    "idle_timeout_sec": 60,
    "shutdown_timeout_sec": 10
  },
  "database": {
    "driver": "mysql",
    "mysql_dsn": "gos:gos123@tcp(mysql:3306)/gos_release?charset=utf8mb4&parseTime=true&loc=UTC",
    "max_open_conns": 20,
    "max_idle_conns": 10,
    "conn_max_lifetime_sec": 1800,
    "conn_max_idle_time_sec": 600,
    "ping_timeout_sec": 5,
    "startup_max_retries": 30,
    "startup_retry_interval_sec": 3
  },
  "jenkins": {
    "enabled": false,
    "base_url": "http://jenkins:8080/",
    "username": "admin",
    "api_token": "",
    "timeout_sec": 60,
    "startup_check_enabled": false,
    "startup_max_retries": 5,
    "startup_retry_interval_sec": 2,
    "auto_sync_enabled": false,
    "auto_sync_interval_sec": 300,
    "release_track_enabled": false,
    "release_track_interval_sec": 10
  },
  "release": {
    "env_options": ["dev", "test", "prod"],
    "concurrency": {
      "enabled": true,
      "lock_scope": "application_env",
      "conflict_strategy": "reject",
      "lock_timeout_sec": 1800
    }
  },
  "auth": {
    "session_ttl_hours": 24,
    "admin_username": "admin",
    "admin_display_name": "Administrator",
    "admin_password": "admin123"
  },
  "security": {
    "encryption_key": "gos-release-production-2026"
  }
}
