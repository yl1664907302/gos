{
  "environment": "production",
  "server": {
    "addr": ":8080",
    "read_header_timeout_sec": 10,
    "read_timeout_sec": 120,
    "write_timeout_sec": 120,
    "idle_timeout_sec": 120,
    "shutdown_timeout_sec": 30
  },
  "database": {
    "driver": "mysql",
    "mysql_dsn": "deploy_app:${MYSQL_PASSWORD}@tcp(mysql-prod.internal.company:3306)/deploy_platform?charset=utf8mb4&parseTime=true&loc=UTC",
    "max_open_conns": 80,
    "max_idle_conns": 20,
    "conn_max_lifetime_sec": 1800,
    "conn_max_idle_time_sec": 600,
    "ping_timeout_sec": 5,
    "startup_max_retries": 20,
    "startup_retry_interval_sec": 3
  },
  "jenkins": {
    "enabled": true,
    "base_url": "https://jenkins.internal.company",
    "username": "deploy_bot",
    "api_token": "${JENKINS_API_TOKEN}",
    "timeout_sec": 5,
    "startup_check_enabled": true,
    "startup_max_retries": 10,
    "startup_retry_interval_sec": 3,
    "auto_sync_enabled": true,
    "auto_sync_interval_sec": 300,
    "release_track_enabled": true,
    "release_track_interval_sec": 10
  },
  "argocd": {
    "enabled": false,
    "base_url": "https://argocd.internal.company",
    "insecure_skip_verify": false,
    "auth_mode": "token",
    "token": "${ARGOCD_TOKEN}",
    "startup_check_enabled": true,
    "sync_enabled": true,
    "sync_interval_sec": 300,
    "request_timeout_sec": 30
  },
  "gitops": {
    "enabled": false,
    "local_root": "/data/gitops",
    "default_branch": "master",
    "username": "gitops_bot",
    "password": "${GITOPS_PASSWORD}",
    "token": "",
    "author_name": "gos-bot",
    "author_email": "gos@example.com",
    "command_timeout_sec": 30
  }
}
